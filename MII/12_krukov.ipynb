   "source": [
    "import numpy as np\n",
    "\n",
    "P = np.array([[1/2, 1/2],\n",
    "              [1/3, 2/3]])\n",
    "\n",
    "P2 = P @ P\n",
    "P3 = P2 @ P\n",
    "\n",
    "print(\"Матрица переходов за три шага P^3:\")\n",
    "print(P3)\n",
    "\n",
    "print(\"\\nПроверка (суммы строк):\")\n",
    "print(P3.sum(axis=1))"
   ],
